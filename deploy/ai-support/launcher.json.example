{
  "protocol_version": 1,
  "codex_binary": "/usr/local/bin/codex",
  "codex_cli_version": "0.142.5",
  "model": "SET_AUDITED_MODEL",
  "codex_home": "/var/lib/denstock-ai/codex-home",
  "runtime_root": "/var/lib/denstock-ai/requests",
  "lock_root": "/run/denstock-ai/locks",
  "ai_user": "denstock-ai",
  "request_creator_uid": 2001,
  "proxy_host": "127.0.0.1",
  "proxy_port": 2080,
  "timeout_seconds": 60,
  "max_prompt_bytes": 24000,
  "max_stdout_bytes": 65536,
  "max_stderr_bytes": 16384,
  "max_image_bytes": 10485760,
  "proxy_service": "denstock-ai-proxy.service",
  "firewall_table": "denstock_ai"
}
