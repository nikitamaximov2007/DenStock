# Пример конфигурации автоматического offsite-бэкапа (v1.1.8B).
# Скопируйте в .env.backup на СЕРВЕРЕ и заполните. .env.backup НЕ коммитится.
# Секреты/ключи offsite здесь НЕ хранятся — они в конфиге rclone на сервере.

# Сколько последних автоматических бэкапов держать локально.
BACKUP_KEEP_LAST=14

# Включить отправку во внешнее хранилище (offsite). false = только локальный бэкап.
BACKUP_OFFSITE_ENABLED=false

# Метод offsite. Поддерживается generic rclone (конфиг remote — на сервере, не в Git).
BACKUP_OFFSITE_METHOD=rclone

# Имя rclone-remote и путь. Это НЕ секрет — сами ключи лежат в ~/.config/rclone/rclone.conf.
BACKUP_OFFSITE_TARGET=remote:denstock-backups

# Куда писать статус для UI (относительно корня проекта).
BACKUP_STATUS_FILE=backups/offsite_status.json

# Имя сервиса web в docker compose (внутри него запускается manage.py backup_all).
BACKUP_WEB_SERVICE=web
