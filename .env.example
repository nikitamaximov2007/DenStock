# Шаблон переменных окружения DenStock.
# Скопируйте в .env и заполните реальными значениями. .env НЕ коммитится.

# --- Django ---
# Сгенерируйте свой ключ, например:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=ЗАМЕНИТЕ-НА-СЛУЧАЙНЫЙ-КЛЮЧ
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_SECURE_COOKIES=false

LANGUAGE_CODE=ru-ru
TIME_ZONE=Europe/Moscow

# --- PostgreSQL ---
POSTGRES_DB=denstock
POSTGRES_USER=denstock
POSTGRES_PASSWORD=ЗАМЕНИТЕ-ПАРОЛЬ
# Хост = имя сервиса из docker-compose (db).
DATABASE_URL=postgres://denstock:ЗАМЕНИТЕ-ПАРОЛЬ@db:5432/denstock

# --- Первичный администратор (создаётся при первом запуске, если задан) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=ЗАМЕНИТЕ-ПАРОЛЬ-АДМИНА
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Caddy (reverse-proxy) ---
# Локально: :80. На VPS укажите домен, чтобы включить авто-HTTPS, например example.com
CADDY_SITE_ADDRESS=:80
