# Шаблон переменных окружения DenStock.
# Скопируйте в .env и заполните реальными значениями. .env НЕ коммитится.

# --- Django ---
# Сгенерируйте свой ключ, например:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=ЗАМЕНИТЕ-НА-СЛУЧАЙНЫЙ-КЛЮЧ
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_SECURE_COOKIES=false

LANGUAGE_CODE=ru-ru
TIME_ZONE=Europe/Moscow

# --- PostgreSQL ---
POSTGRES_DB=denstock
POSTGRES_USER=denstock
POSTGRES_PASSWORD=ЗАМЕНИТЕ-ПАРОЛЬ
# Хост = имя сервиса из docker-compose (db).
DATABASE_URL=postgres://denstock:ЗАМЕНИТЕ-ПАРОЛЬ@db:5432/denstock

# --- Первичный администратор (создаётся при первом запуске, если задан) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=ЗАМЕНИТЕ-ПАРОЛЬ-АДМИНА
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Caddy (reverse-proxy) ---
# Локально: :80. На VPS укажите домен, чтобы включить авто-HTTPS, например example.com
CADDY_SITE_ADDRESS=:80

# --- ИИ-поддержка (read-only, по умолчанию выключена) ---
# Приватные скриншоты хранятся отдельно от публичного media.
PRIVATE_MEDIA_ROOT=/app/private_media
AI_SUPPORT_ENABLED=false
AI_SUPPORT_PROVIDER=disabled
# Codex CLI uses ChatGPT subscription authentication from this isolated home.
# Run login manually as the dedicated OS user; never commit or back up auth.json.
AI_SUPPORT_CODEX_BINARY=codex
AI_SUPPORT_CODEX_MODEL=
AI_SUPPORT_CODEX_HOME=/var/lib/denstock-ai/codex-home
AI_SUPPORT_CODEX_WORKSPACE=/var/lib/denstock-ai/runtime
AI_SUPPORT_CODEX_TIMEOUT_SECONDS=60
AI_SUPPORT_CODEX_MAX_OUTPUT_BYTES=65536
AI_SUPPORT_CODEX_MAX_STDERR_BYTES=16384
AI_SUPPORT_CODEX_MAX_PROMPT_CHARS=24000
AI_SUPPORT_CODEX_MAX_HISTORY_CHARS=12000
AI_SUPPORT_CODEX_MAX_CONCURRENT=2
AI_SUPPORT_MAX_MESSAGE_CHARS=8000
AI_SUPPORT_MAX_OUTPUT_TOKENS=1200
AI_SUPPORT_RATE_LIMIT=5
AI_SUPPORT_DAILY_REQUEST_LIMIT=50
AI_SUPPORT_DAILY_TOKEN_LIMIT=100000
AI_SUPPORT_MAX_IMAGE_BYTES=5242880
AI_SUPPORT_ATTACHMENT_RETENTION_DAYS=30
AI_SUPPORT_CONVERSATION_RETENTION_DAYS=180
# Канонический публичный адрес, например https://185-250-44-206.sslip.io/
DENSTOCK_PUBLIC_BASE_URL=
# Безопасный release metadata. HTTP-запросы не запускают git.
DENSTOCK_APP_COMMIT=

# --- Эксплуатация / резервные копии (Слой 25) ---
# Каталог бэкапов БД и media. По умолчанию backups/ в корне проекта (в git НЕ коммитится).
# В docker-compose он смонтирован на хост через ./backups:/app/backups.
# BACKUP_ROOT=/app/backups
# Загруженные фото лежат в mediafiles/ (в compose — именованный том media).
# Приватный том private_media не включён в текущий offsite backup автоматически.

# --- Аварийное веб-восстановление (Layer 30) ---
# По умолчанию ВЫКЛЮЧЕНО. Включать только на время аварийного восстановления.
# Restore в веб-интерфейсе видит ТОЛЬКО администратор из allowlist ниже.
# DENSTOCK_ENABLE_WEB_RESTORE=true
# DENSTOCK_RESTORE_ALLOWED_EMAILS=nikita.maximov2007@gmail.com
# DENSTOCK_RESTORE_ALLOWED_USERNAMES=
