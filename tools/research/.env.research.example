# Copy this file to .env.research.local and fill values locally.
# Do not commit .env.research.local.

TG_API_ID=
TG_API_HASH=
YT_API_KEY=

RESEARCH_LIMIT=50
RESEARCH_COMMENT_LIMIT=100

# WST private-channel collector. Values below are safe defaults, not credentials.
WST_CHANNEL_ID=3278525266
WST_NAVIGATION_MESSAGE_ID=3
WST_OUTPUT_ROOT=research_inputs/wst
WST_WHISPER_MODEL=large-v3
WST_OCR_LANGUAGES=rus+eng
